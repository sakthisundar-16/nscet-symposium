RewriteEngine On

# ── Security ────────────────────────────────────────────────────────────────
Options -Indexes

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "config\.php$">
    Require all denied
</FilesMatch>

# ── HTTPS Redirect (uncomment in production) ────────────────────────────────
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Error Pages ─────────────────────────────────────────────────────────────
ErrorDocument 404 /404.php
ErrorDocument 403 /403.php
ErrorDocument 500 /500.php

# ── PHP Settings ─────────────────────────────────────────────────────────────
php_flag display_errors Off
php_value upload_max_filesize 12M
php_value post_max_size 15M
php_value max_execution_time 300

# ── React SPA Routing ───────────────────────────────────────────────────────
# Pass PHP/API/asset requests directly (do NOT rewrite them)
RewriteCond %{REQUEST_URI} ^/api/           [OR]
RewriteCond %{REQUEST_URI} ^/includes/      [OR]
RewriteCond %{REQUEST_URI} ^/assets/        [OR]
RewriteCond %{REQUEST_URI} ^/reactapp/      [OR]
RewriteCond %{REQUEST_URI} ^/uploads/       [OR]
RewriteCond %{REQUEST_URI} ^/admin/         [OR]
RewriteCond %{REQUEST_URI} ^/coordinator/
RewriteRule ^ - [L]

# If request is for a real file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# All other requests → React index.html (SPA client-side routing)
RewriteRule ^ index.html [L]

# ── Browser Caching ──────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg           "access 1 year"
    ExpiresByType image/jpeg          "access 1 year"
    ExpiresByType image/gif           "access 1 year"
    ExpiresByType image/png           "access 1 year"
    ExpiresByType image/svg+xml       "access 1 year"
    ExpiresByType image/webp          "access 1 year"
    ExpiresByType text/css            "access 1 month"
    ExpiresByType text/javascript     "access 1 month"
    ExpiresByType application/javascript "access 1 month"
    ExpiresByType application/pdf     "access 1 month"
    ExpiresByType image/x-icon        "access 1 year"
    ExpiresDefault                    "access 1 month"
</IfModule>

# ── Gzip Compression ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Cache-bust for hashed React assets
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
